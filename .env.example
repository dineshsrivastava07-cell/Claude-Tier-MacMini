# ─────────────────────────────────────────────────────────────────────────────
# tier-router-mcp  ·  Environment Variables
# Copy to .env and fill in values as needed.
# ─────────────────────────────────────────────────────────────────────────────

# ── T1 Ollama ────────────────────────────────────────────────────────────────
# Local Ollama host (default: http://localhost:11434)
OLLAMA_LOCAL_HOST=http://localhost:11434

# Remote/cloud Ollama host for qwen3-coder:480b-cloud
# Leave unset to use local Ollama for the cloud model too
# OLLAMA_CLOUD_HOST=http://your-remote-server:11434

# Timeouts (ms)
T1_LOCAL_TIMEOUT_MS=90000
T1_CLOUD_TIMEOUT_MS=300000

# ── T2 Gemini ────────────────────────────────────────────────────────────────
# Optional: set for API key auth. If unset, uses gemini CLI (account auth).
# GEMINI_API_KEY=your-gemini-api-key-here

# Timeout (ms)
T2_TIMEOUT_MS=60000

# ── T3 Claude ────────────────────────────────────────────────────────────────
# Optional: set for API key auth. If unset, uses claude CLI (account auth).
# ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Claude model to use (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# Timeout (ms)
T3_TIMEOUT_MS=120000

# ── Quality Gate ─────────────────────────────────────────────────────────────
# Minimum quality score (0.0–1.0) to accept a tier's response
# Default: 0.75
QUALITY_THRESHOLD=0.75

# ── HTTP Transport (optional) ─────────────────────────────────────────────────
# Set PORT to enable HTTP/SSE transport alongside stdio
# PORT=3001
